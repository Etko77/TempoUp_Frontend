# Copy this file to .env and adjust as needed. Loaded by app.config.js via dotenv.
# .env is gitignored — never commit real values.

# Backend URLs read into expo.extra (see src/api/client.ts for the fallbacks)
#   Android emulator        -> http://10.0.2.2:8080   ws://10.0.2.2:8080
#   iOS simulator           -> http://localhost:8080  ws://localhost:8080
#   Physical phone (Expo Go)-> http://<your-LAN-IP>:8080  ws://<your-LAN-IP>:8080
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080
EXPO_PUBLIC_WS_BASE_URL=ws://10.0.2.2:8080

# Optional app identity overrides (defaults live in app.config.js)
# APP_NAME=TempoUp
# APP_SLUG=tempoup
# APP_VERSION=0.1.0
# IOS_BUNDLE_ID=com.tempoup.mobile
# ANDROID_PACKAGE=com.tempoup.mobile
